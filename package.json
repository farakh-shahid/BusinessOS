{
  "name": "business-os",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:frontend:demo": "npm run dev:demo --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:web": "npm run dev --workspace=frontend",
    "dev:api": "npm run dev --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "vercel-build:backend": "npm run vercel-build --workspace=backend",
    "build:web": "npm run build --workspace=frontend",
    "build:api": "npm run build --workspace=backend",
    "lint:frontend": "npm run lint --workspace=frontend",
    "lint:web": "npm run lint --workspace=frontend",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "npm run prisma:migrate --workspace=backend",
    "db:deploy": "npm run prisma:deploy --workspace=backend",
    "db:seed": "npm run prisma:seed --workspace=backend",
    "db:deploy:seed": "npm run db:deploy:seed --workspace=backend",
    "db:studio": "npm run prisma:studio --workspace=backend"
  }
}
