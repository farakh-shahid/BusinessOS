{
  "name": "business-os",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=businessos-frontend",
    "dev:frontend:demo": "npm run dev:demo --workspace=businessos-frontend",
    "dev:backend": "npm run dev --workspace=businessos-backend",
    "dev:web": "npm run dev --workspace=businessos-frontend",
    "dev:api": "npm run dev --workspace=businessos-backend",
    "build:frontend": "npm run build --workspace=businessos-frontend",
    "build:backend": "npm run build --workspace=businessos-backend",
    "build:web": "npm run build --workspace=businessos-frontend",
    "build:api": "npm run build --workspace=businessos-backend",
    "lint:frontend": "npm run lint --workspace=businessos-frontend",
    "lint:web": "npm run lint --workspace=businessos-frontend",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "npm run prisma:migrate --workspace=businessos-backend",
    "db:seed": "npm run prisma:seed --workspace=businessos-backend",
    "db:studio": "npm run prisma:studio --workspace=businessos-backend"
  }
}
