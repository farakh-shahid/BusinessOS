# Copy to .env and adjust when you have production credentials
#
# Local dev (recommended with `npm run db:up`):
DATABASE_URL="postgresql://businessos:businessos@localhost:5433/businessos"
#
# Neon / production (use on Vercel; can ETIMEDOUT on slow networks locally):
# DATABASE_URL="postgresql://USER:PASS@HOST/businessos?sslmode=require"
JWT_SECRET="dev-jwt-secret-change-me"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000"
PORT=3001

# Optional — system emails when staff marks order ready (e.g. Gmail SMTP)
SMTP_HOST=
# Use 465 if 587 is blocked on your network (Gmail SSL)
SMTP_PORT=465
SMTP_USER=
# Quote if your Gmail app password contains spaces
SMTP_PASS=
SMTP_FROM="Demo Tailor Shop <noreply@businessos.pk>"

# WhatsApp — three options (app tries in order, then falls back to wa.me link):
#
# 1) FREE (default): wa.me link opens WhatsApp with message pre-filled.
#    Staff tap Send from the shop phone (+923168843648) logged into WhatsApp Web/app.
#
# 2) Meta Cloud API (recommended if you want auto-send from YOUR number, no Twilio):
#    Register at https://developers.facebook.com — connect WhatsApp Business Account,
#    verify your shop number (+923168843648), add payment method in Meta Business Manager.
#    Utility reminders in Pakistan ≈ PKR 3/msg; FREE if customer messaged you in last 24h.
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
# Optional approved templates (create in Meta Business Manager → WhatsApp → Message templates):
WHATSAPP_TEMPLATE_REMINDER=
WHATSAPP_TEMPLATE_READY=
#
# 3) Twilio (paid BSP — adds markup on top of Meta rates)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

SHOP_NAME="Demo Tailor Shop"

# Cloudinary — dress/suit reference photos (recommended for production / Vercel)
# Existing customer: {prefix}/{tenantId}/customers/{customerId}/suits/{suitIndex}/
# New customer:     {prefix}/{tenantId}/dress-images/{suitIndex}/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional — defaults to "businessos"
CLOUDINARY_FOLDER_PREFIX=businessos
